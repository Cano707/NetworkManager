{
    "version": 1.0,
    "formatters": {
        "command": {
            "format": "%(asctime)s - %(funcname)s - %(message)s"
        },
        "error": {
            "format": "%(asctime)s - %(name)s - %(levelname)s - %(funcname)s:%(lineno)d - %(message)s"
        }
    },

    "handlers": {
        
    }

}